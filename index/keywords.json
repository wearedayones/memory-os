{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Keyword Index",
  "description": "Inverted keyword index used to retrieve sessions by term. Optional utility file.",
  "type": "object",
  "required": ["version", "updated_at", "keywords"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version of this file."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of the most recent update."
    },
    "keywords": {
      "type": "object",
      "description": "Mapping from normalized keyword to session references.",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["session_id", "user_id"],
          "properties": {
            "session_id": {
              "type": "string",
              "description": "Unique session identifier."
            },
            "user_id": {
              "type": "string",
              "pattern": "^[a-z0-9_-]+$",
              "description": "Owner of the session."
            },
            "score": {
              "type": "number",
              "minimum": 0,
              "description": "Optional relevance score."
            },
            "positions": {
              "type": "array",
              "items": {"type": "integer", "minimum": 0},
              "description": "Optional occurrence positions in source text."
            }
          },
          "additionalProperties": false
        }
      }
    }
  },
  "additionalProperties": false
}
